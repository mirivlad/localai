# ========== API настройки ==========
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ========== OpenAI ==========
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-3.5-turbo

# ========== OpenRouter ==========
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat

# ========== Локальная модель (LM Studio / llama.cpp) ==========
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_API_KEY=sk-no-key-required
LOCAL_LLM_DEFAULT_MODEL=local-model

# ========== GigaChat ==========
GIGACHAT_CLIENT_ID=your-client-id
GIGACHAT_CLIENT_SECRET=your-client-secret
GIGACHAT_PROFILE=default
GIGACHAT_MODEL=GigaChat-Pro

# ========== YandexGPT ==========
YANDEX_FOLDER_ID=your-folder-id
YANDEX_API_KEY=your-api-key
YANDEX_GPT_MODEL=yandexgpt-lite

# ========== Telegram Bot ==========
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ========== Fallback chain (порядок, если модель недоступна) ==========
FALLBACK_CHAIN=local_llm,openrouter,openai,gigachat,yandexgpt

# ========== Пути к моделям (опционально) ==========

# Модель эмбеддингов
EMBEDDING_MODEL=all-MiniLM-L6-v2  # Имя модели (скачается автоматически)
EMBEDDING_MODEL_PATH=./models/embeddings  # Или путь к скачанной модели

# FAISS индекс
VECTOR_INDEX_PATH=./data/faiss_index

# Whisper (STT)
WHISPER_MODEL=base  # tiny, base, small, medium, large
WHISPER_MODEL_PATH=  # Или путь к локальной модели

# Piper TTS
PIPER_EXECUTABLE=piper
PIPER_MODEL_PATH=./models/piper/ru_RU-irina.onnx

# Coqui TTS
COQUI_MODEL=tts_models/ru/tacotron2-DDC
COQUI_MODEL_PATH=./models/coqui  # Или путь к скачанной модели
